        </div>

        <div class="footer">
            <div class="left">
                <div class="phone">+353 871986494</div>
                <div class="divider"></div>
                <div class="email">info@taxmind.ie</div>
            </div>
            <div class="socials">
                <img src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/X.png" alt="x">
                <img src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/facebook.png" alt="facebook">
