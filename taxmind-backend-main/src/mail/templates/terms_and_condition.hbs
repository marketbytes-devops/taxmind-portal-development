<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Terms and Conditions - Taxmind</title>
    <style>
        /* Basic reset */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', Arial, sans-serif;
            background: #ffffff;
            color: #222;
        }

        .page {
            max-width: 980px;
            margin: 0 auto;
            padding: 24px;
        }

        /* Banner */
        .banner {
            width: 100%;
            background-size: cover !important;
            background-position: center !important;
            background-repeat: no-repeat !important;
        }

        /* Main content */
        .card {
            background: #fff;
            padding: 32px;
            margin-top: 0px;
            border-radius: 6px;
        }

        h1 {
            font-size: 28px;
            margin-bottom: 18px;
        }

        .lead {
            color: #666;
            margin-bottom: 22px;
            line-height: 1.6;
        }

        .section {
            margin-bottom: 22px;
        }

        .section h3 {
            font-size: 16px;
            margin-bottom: 8px;
        }

        .section p {
            color: #666;
            line-height: 1.6;
        }

        /* Checkbox + button */
        .agree {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 18px;
        }

        .agree input[type="checkbox"] {
            width: 18px;
            height: 18px;
        }

        .btn {
            display: inline-block;
            background: #1779ff;
            color: #fff;
            padding: 10px 18px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: 500;
            margin-top: 16px;
        }

        /* Footer */
        .footer {
            background: #00b0ea;
            color: #fff;
            margin-top: 0px;
            padding: 14px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .footer .left {
            display: flex;
            gap: 24px;
            align-items: center;
        }

        .footer .divider {
            width: 1px;
            height: 28px;
            background: rgba(255, 255, 255, 0.35);
        }

        .footer .socials img {
            width: 20px;
            height: 20px;
            margin-left: 12px;
        }

        /* Responsive */
        @media (max-width: 640px) {
            .page {
                padding: 12px;
            }

            .banner {
                height: 150px !important;
            }

            .banner td {
                padding: 20px 0 0 24px !important;
            }

            .banner img {
                width: 100px !important;
                height: 24px !important;
            }

            .card {
                padding: 18px;
            }

            h1 {
                font-size: 22px;
            }

            .footer {
                flex-direction: column;
                gap: 12px;
                align-items: center;
                text-align: center;
                padding: 12px;
            }

            .footer .left {
                gap: 8px;
            }

            .footer .socials {
                margin-top: 6px;
            }
        }
    </style>
</head>

<body>
    <div class="page">
        <table width="100%" border="0" cellspacing="0" cellpadding="0" class="banner" style="background-image: url('https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/banner_image.png'); background-size: cover; background-position: center; background-repeat: no-repeat; height: 80px;">
            <tr>
