# Root Gitignore for TaxMind Repository
# Ignore all environment files in any directory
.env
.env.*
.env.local
.env.development
.env.production
.env.staging

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
/dist/
/build/

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Test outputs from preparation
/taxmind-backend-main/error.json
/taxmind-backend-main/error.log
/taxmind-backend-main/query-out.txt
/taxmind-backend-main/test-output.pdf
/taxmind-backend-main/user_results.json
/taxmind-backend-main/test-*.ts
/taxmind-backend-main/testPdf.ts
