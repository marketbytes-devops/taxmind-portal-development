FROM public.ecr.aws/docker/library/node:22-alpine AS build-stage

WORKDIR /app

# Copy dependency files first for caching
COPY package*.json ./
RUN npm install

# Copy the rest of your source
COPY . .

# --- Accept ALL build args from CodeBuild ---
ARG VUE_APP_API_BASE_URL
ARG VUE_APP_TOKEN_HEADER
ARG VUE_APP_SOCKET_URL
ARG VUE_APP_WHATSAPP_PHONE_NUMBER_ID
ARG VUE_APP_WHATSAPP_ACCESS_TOKEN
ARG VUE_APP_FIREBASE_API_KEY
ARG VUE_APP_FIREBASE_AUTH_DOMAIN
ARG VUE_APP_FIREBASE_PROJECT_ID
ARG VUE_APP_FIREBASE_STORAGE_BUCKET
ARG VUE_APP_FIREBASE_MESSAGING_SENDER_ID
ARG VUE_APP_FIREBASE_APP_ID
ARG VUE_APP_FIREBASE_MEASUREMENT_ID
ARG VUE_APP_FIREBASE_VAPID_KEY

# --- Make ALL of them available to the Vue build process ---
ENV VUE_APP_API_BASE_URL=$VUE_APP_API_BASE_URL
ENV VUE_APP_TOKEN_HEADER=$VUE_APP_TOKEN_HEADER
ENV VUE_APP_SOCKET_URL=$VUE_APP_SOCKET_URL
ENV VUE_APP_WHATSAPP_PHONE_NUMBER_ID=$VUE_APP_WHATSAPP_PHONE_NUMBER_ID
ENV VUE_APP_WHATSAPP_ACCESS_TOKEN=$VUE_APP_WHATSAPP_ACCESS_TOKEN
ENV VUE_APP_FIREBASE_API_KEY=$VUE_APP_FIREBASE_API_KEY
ENV VUE_APP_FIREBASE_AUTH_DOMAIN=$VUE_APP_FIREBASE_AUTH_DOMAIN
ENV VUE_APP_FIREBASE_PROJECT_ID=$VUE_APP_FIREBASE_PROJECT_ID
ENV VUE_APP_FIREBASE_STORAGE_BUCKET=$VUE_APP_FIREBASE_STORAGE_BUCKET
ENV VUE_APP_FIREBASE_MESSAGING_SENDER_ID=$VUE_APP_FIREBASE_MESSAGING_SENDER_ID
ENV VUE_APP_FIREBASE_APP_ID=$VUE_APP_FIREBASE_APP_ID
ENV VUE_APP_FIREBASE_MEASUREMENT_ID=$VUE_APP_FIREBASE_MEASUREMENT_ID
ENV VUE_APP_FIREBASE_VAPID_KEY=$VUE_APP_FIREBASE_VAPID_KEY

# --- Build the app with ALL env vars injected ---
RUN echo "Building with:"
RUN echo "VUE_APP_API_BASE_URL=$VUE_APP_API_BASE_URL"
RUN echo "VUE_APP_SOCKET_URL=$VUE_APP_SOCKET_URL"
RUN echo "VUE_APP_WHATSAPP_PHONE_NUMBER_ID=$VUE_APP_WHATSAPP_PHONE_NUMBER_ID"
RUN echo "VUE_APP_WHATSAPP_ACCESS_TOKEN=$(echo $VUE_APP_WHATSAPP_ACCESS_TOKEN | cut -c1-10)..."  # FIXED: Use cut instead of string slicing
RUN echo "VUE_APP_FIREBASE_API_KEY=$VUE_APP_FIREBASE_API_KEY"
RUN echo "VUE_APP_FIREBASE_AUTH_DOMAIN=$VUE_APP_FIREBASE_AUTH_DOMAIN"
RUN echo "VUE_APP_FIREBASE_PROJECT_ID=$VUE_APP_FIREBASE_PROJECT_ID"
RUN echo "VUE_APP_FIREBASE_STORAGE_BUCKET=$VUE_APP_FIREBASE_STORAGE_BUCKET"
RUN echo "VUE_APP_FIREBASE_MESSAGING_SENDER_ID=$VUE_APP_FIREBASE_MESSAGING_SENDER_ID"
RUN echo "VUE_APP_FIREBASE_APP_ID=$VUE_APP_FIREBASE_APP_ID"
RUN echo "VUE_APP_FIREBASE_MEASUREMENT_ID=$VUE_APP_FIREBASE_MEASUREMENT_ID"
RUN echo "VUE_APP_FIREBASE_VAPID_KEY=$VUE_APP_FIREBASE_VAPID_KEY"
RUN npm run build

# ===========================
# Stage 2: Serve with Nginx
# ===========================
FROM public.ecr.aws/nginx/nginx:alpine

# Copy built app from previous stage
COPY --from=build-stage /app/dist /usr/share/nginx/html

# Copy your custom Nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
