        this.LABELS = {
          ...this.LABELS,
          CREATE_QUESTIONNAIRE_TITLE: `View Questionnaire`,
          IMPORTED_FROM: `Questionnaire Details`,
        };

        console.log("✅ Questionnaire details loaded");
      } catch (error) {
        console.error("❌ Error loading questionnaire details:", error);
        this.msg = "Error loading questionnaire details";
        this.showSnackBar = true;
      }
    },

    handleBack() {
      console.log("🔙 Back button clicked");
      this.$router.push({ name: "questionnaire" });
    },

    handleQuestionAnswered(questionId, answer) {
      console.log("� Question answered:", { questionId, answer });
      this.responses[questionId] = answer;
      
      // TODO: Auto-save responses or implement save logic
      console.log("💾 Current responses:", this.responses);
    },

    async loadCategories() {
      console.log("🔄 Loading categories from API...");
      this.appLoading = true;

      try {
        let result;

        if (this.questionnaireId) {
          console.log(
            "� Loading categories for questionnaire:",
            this.questionnaireId
          );
          result = await questionnaireApi.listCategories(this.questionnaireId);
        } else {
          console.log("🌍 Loading all global categories");
          result = await questionnaireApi.listAllCategories();
        }

        const { success, data, message } = result;

        if (success) {
          this.categories = data || [];
          console.log(
            "✅ Categories loaded successfully:",
            this.categories.length,
            "categories"
          );
          if (this.questionnaireId) {
            console.log(
              "ℹ️ Categories for questionnaire",
              this.questionnaireId
            );
          } else {
            console.log("ℹ️ Global categories loaded");
          }
        } else {
          console.error("❌ Failed to load categories:", message);
          this.msg = message || "Failed to load categories";
          this.showSnackBar = true;
        }
      } catch (error) {
        console.error("❌ Error loading categories:", error);
        this.msg = "Error loading categories";
        this.showSnackBar = true;
      } finally {
        this.appLoading = false;
      }
    },


  },
};
</script>

