<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OffBoard Users - Taxmind</title>
    <style type="text/css">
        /* Reset and global fixes to prevent horizontal overflow */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
        }

        html,
        body {
            overflow-x: hidden;
        }

        body,
        table,
        td,
        p,
        a,
        li,
        blockquote {
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table,
        td {
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        img {
            -ms-interpolation-mode: bicubic;
            max-width: 100%;
            height: auto;
            display: block;
        }

        /* Font */
        body {
            font-family: 'DM Sans', Arial, sans-serif;
            background-color: #ffffff;
            margin: 0;
            padding: 0;
        }

        /* Container */
        .container {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
        }

        /* Banner */
        .banner {
            width: 100%;
            background-size: cover !important;
            background-position: center !important;
            background-repeat: no-repeat !important;
        }

        /* Content */
        .content {
            padding: 0 48px;
        }

        .title {
            font-size: 24px;
            font-weight: bold;
            color: #000000;
            line-height: 1.4;
            margin: 19px 0;
        }

        .greeting {
            font-size: 16px;
            color: #5f5f5f;
            letter-spacing: 0.2px;
            margin: 19px 0;
        }

        .name {
            font-weight: 500;
            color: #000000;
        }

        .otp-section {
            font-size: 16px;
            color: #5f5f5f;
            letter-spacing: 0.2px;
            margin: 19px 0;
        }

        .otp-code {
            font-weight: bold;
            color: #1a73e9;
            font-size: 16px;
            margin: 8px 0;
        }

        .instructions {
            font-size: 16px;
            color: #5f5f5f;
            letter-spacing: 0.2px;
            line-height: 1.5;
            margin: 19px 0;
        }

        .instructions p {
            margin: 0;
        }

        /* Footer */
        .footer {
            background-color: #01afed;
            padding: 16px 48px;
        }

        .contact-info {
            color: #ffffff;
            font-size: 14px;
            letter-spacing: 0.2px;

        }

        .contact-divider {
            display: inline-block;
            width: 1px;
            height: 19px;
            background-color: #ffffff;
            opacity: 0.5;
            margin: 0 10px;
        }

        /* Link color used across templates */
        a.color {
            color: #1A73E9;
            text-decoration: none;
        }

        a.color:hover,
        a.color:focus {
            text-decoration: underline;
        }

        /* .social-icons {
            margin-top: 0;
        } */
        .social-icon {
            width: 16px;
            height: 16px;
            /* margin: 0 5px; */
            display: inline-block;
        }

        /* Responsive */
        @media only screen and (max-width: 640px) {
            .container {
                width: 100% !important;
            }

            .banner {
                height: 150px !important;
            }

            .banner td {
                padding: 20px 0 0 24px !important;
            }

            .banner img {
                width: 100px !important;
                height: 24px !important;
            }

            .content {
                padding: 0 24px !important;
            }

            .title {
                font-size: 20px;
            }

            .footer {
                padding: 16px 24px;

            }

            .contact-info {
                font-size: 12px;
                text-align: center !important;

            }

            .social-icons {
                text-align: center !important;
            }

            .footer table,
            .footer tr,
            .footer td {
                display: block !important;
                width: 100% !important;
                text-align: center !important;
                justify-content: center !important;

            }

        }
    </style>
</head>

<body>
    <div
        style="width: 100%; max-width: 600px; margin: 0 auto; background-color: #ffffff; padding: 24px; box-sizing: border-box;">
        <!-- Banner with background image and logo -->
        <table width="100%" border="0" cellspacing="0" cellpadding="0" class="banner" style="background-image: url('https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/banner_image.png'); background-size: cover; background-position: center; background-repeat: no-repeat; height: 80px;">
            <tr>
                <td align="left" valign="top" style="padding: 31px 0 0 48px;">
                    <img src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/logo.png" alt="Taxmind Logo" style="width: 119px; height: 29px; display: block;">
                </td>
            </tr>
        </table>
        <!-- Content and Footer -->
        <table width="100%" border="0" cellspacing="0" cellpadding="0">
            <tr>
                <td class="content" style="padding: 0 48px;">

                    <img src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/user_block.png"
                        alt="User illustration" style="display:inline-block; margin: 18px 0 0 0; height: 60px;">

                    <h1 class="title"
                        style="font-size: 24px; font-weight: bold; color: #000000; line-height: 1.4; margin: 19px 0;">
                    Account Access Removal Notice
                    </h1>
                    <p class="greeting" style="font-size: 16px; color: #5f5f5f; letter-spacing: 0.2px; margin: 19px 0;">
                        Hi <span class="name" style="font-weight: 500; color: #000000;">{{name}}</span> 👋
                    </p>

                    <div class="instructions"
                        style="font-size: 16px; color: #5f5f5f; letter-spacing: 0.2px; line-height: 1.5; margin: 19px 0;">
                        <p>This is to inform you that your TaxMind account access has been removed following the unlinking of our agent connection from your Revenue account. As a result, you no longer have access to your TaxMind account or related services.</p>
                         <br>
                        <p>In accordance with GDPR and Revenue guidelines, your account has been marked as inactive.</p>
                        <p>While your access is removed, your personal and tax data will remain securely stored for up to six (6) years, as required by Revenue record retention regulations.</p>
                        <br>
                        <p>During the first 14 days from this notice, if the agent unlinking was done in error or you wish to reinstate TaxMind as your Revenue agent, please contact info@taxmind.ie.</p>
                        <br>
                        <p>Your data remains protected and will only be accessed if required for legal, audit, or compliance purposes. After the statutory period, all records will be permanently deleted.</p>
                        <br>
                        <p>Thank you for the time you’ve spent with TaxMind. <br> We wish you all the best going forward.</p>
                        <br>
                        <p>Kind regards,<br>
                            Team Taxmind</p>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="footer" style="background-color: #01afed; padding: 16px 48px;">
                    <table width="100%" border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td align="center" valign="middle" class="contact-info"
                                style="color: #ffffff; font-size: 14px; letter-spacing: 0.2px; vertical-align: middle;">
                                <span>+353 871986494</span>
                                <span class="contact-divider"
                                    style="display: inline-block; width: 1px; height: 19px; background-color: #ffffff; opacity: 0.5; margin: 0 10px; vertical-align: middle;"></span>
                                <span>info@taxmind.ie</span>
                                <span class="contact-divider"
                                    style="display: inline-block; width: 1px; height: 19px; background-color: #ffffff; opacity: 0.5; margin: 0 10px; vertical-align: middle;"></span>
                                <!-- </td>
                            <td align="right" valign="middle" class="social-icons" style="text-align: right; vertical-align: middle;"> -->
                                <img src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/X.png" alt="Twitter"
                                    class="social-icon"
                                    style="width: 16px; height: 16px; margin: 0 5px; display: inline-block; vertical-align: middle;">
                                <img src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/facebook.png"
                                    alt="Facebook" class="social-icon"
                                    style="width: 16px; height: 16px; margin: 0 5px; display: inline-block; vertical-align: middle;">
                                <img src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/instagram.png"
                                    alt="Instagram" class="social-icon"
                                    style="width: 16px; height: 16px; margin: 0 5px; display: inline-block; vertical-align: middle;">
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </div>
</body>

</html>