<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Application Submitted - Taxmind</title>
    <style type="text/css">
      /* Reset and global fixes to prevent horizontal overflow */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html,
      body {
        overflow-x: hidden;
      }

      body,
      table,
      td,
      p,
      a,
      li,
      blockquote {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }

      img {
        -ms-interpolation-mode: bicubic;
        max-width: 100%;
        height: auto;
        display: block;
      }

      /* Font */
      body {
        font-family: 'DM Sans', Arial, sans-serif;
        background-color: #ffffff;
        margin: 0;
        padding: 0;
      }

      /* Container */
      .container {
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
      }

      /* Banner */
      .banner {
        width: 100%;
        background-size: cover !important;
        background-position: center !important;
        background-repeat: no-repeat !important;
      }

      /* Content */
      .content {
        padding: 0 48px;
      }

      .title {
        font-size: 24px;
        font-weight: bold;
        color: #000000;
        line-height: 1.4;
        margin: 19px 0;
      }

      .greeting {
        font-size: 16px;
        color: #5f5f5f;
        letter-spacing: 0.2px;
        margin: 19px 0;
      }

      .name {
        font-weight: 500;
        color: #000000;
      }

      .otp-section {
        font-size: 16px;
        color: #5f5f5f;
        letter-spacing: 0.2px;
        margin: 19px 0;
      }

      .otp-code {
        font-weight: bold;
        color: #1a73e9;
        font-size: 16px;
        margin: 8px 0;
      }

      .instructions {
        font-size: 16px;
        color: #5f5f5f;
        letter-spacing: 0.2px;
        line-height: 1.5;
        margin: 19px 0;
      }

      .instructions p {
        margin: 0;
      }

      /* Footer */
      .footer {
        background-color: #01afed;
        padding: 16px 48px;
      }

      .contact-info {
        color: #ffffff;
        font-size: 14px;
        letter-spacing: 0.2px;
      }

      .contact-divider {
        display: inline-block;
        width: 1px;
        height: 19px;
        background-color: #ffffff;
        opacity: 0.5;
        margin: 0 10px;
      }

      /* Link color used across templates */
      a.color {
        color: #1a73e9;
        text-decoration: none;
      }

      a.color:hover,
      a.color:focus {
        text-decoration: underline;
      }

      /* .social-icons {
            margin-top: 0;
        } */
      .social-icon {
        width: 16px;
        height: 16px;
        /* margin: 0 5px; */
        display: inline-block;
      }

      /* Responsive */
      @media only screen and (max-width: 640px) {
        .container {
          width: 100% !important;
        }

        .banner {
          height: 150px !important;
        }

        .banner td {
          padding: 20px 0 0 24px !important;
        }

        .banner img {
          width: 100px !important;
          height: 24px !important;
        }

        .content {
          padding: 0 24px !important;
        }

        .title {
          font-size: 20px;
        }

        .footer {
          padding: 16px 24px;
        }

        .contact-info {
          font-size: 12px;
          text-align: center !important;
        }

        .social-icons {
          text-align: center !important;
        }

        .footer table,
        .footer tr,
        .footer td {
          display: block !important;
          width: 100% !important;
          text-align: center !important;
          justify-content: center !important;
        }
      }
    </style>
  </head>

  <body>
    <div
      style="
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        padding: 24px;
        box-sizing: border-box;
      "
    >
      <!-- Banner with background image and logo -->
      <table
        width="100%"
        border="0"
        cellspacing="0"
        cellpadding="0"
        class="banner"
        style="
          background-image: url('https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/banner_image.png');
          background-size: cover;
          background-position: center;
          background-repeat: no-repeat;
          height: 80px;
        "
      >
        <tr>
          <td align="left" valign="top" style="padding: 31px 0 0 48px">
            <img
              src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/logo.png"
              alt="Taxmind Logo"
              style="width: 119px; height: 29px; display: block"
            />
          </td>
        </tr>
      </table>
      <!-- Content and Footer -->
      <table width="100%" border="0" cellspacing="0" cellpadding="0">
        <tr>
          <td class="content" style="padding: 0 48px">
            <img
              src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/tick_block.png"
              alt="Account illustration"
              style="display: inline-block; margin: 18px 0 0 0; height: 60px"
            />

            <h1
              class="title"
              style="
                font-size: 24px;
                font-weight: bold;
                color: #000000;
                line-height: 1.4;
                margin: 19px 0;
              "
            >
              New Application Submitted
            </h1>
            <p
              class="greeting"
              style="font-size: 16px; color: #5f5f5f; letter-spacing: 0.2px; margin: 19px 0"
            >
              Hello ,
            </p>

            <div
              class="instructions"
              style="
                font-size: 16px;
                color: #5f5f5f;
                letter-spacing: 0.2px;
                line-height: 1.5;
                margin: 19px 0;
              "
            >
              <p>
                A new application has been submitted on the Taxmmind website. Please find the
                details below:
              </p>
              <br />
              <p>Application details:</p>
              <ul style="list-style-type: none; padding: 0; margin: 0">
                <li>Application No : {{applicationNumber}}</li>
                <li>Name : {{name}}</li>
                <li>PPS Number : {{ppsNumber}}</li>
                <li>Email ID : {{email}}</li>
                <li>Phone Number : {{phoneNumber}}</li>
                <li>Submitted On : {{date}}</li>
              </ul>
              <br />
              <p>
                You can view and review the full application in the Admin Portal using the link
                below:
              </p>
              <div style="margin-top: 8px">
                <a
                  href="{{adminPortalLink}}"
                  style="
                    display: inline-block;
                    background-color: #1a73e9;
                    color: #ffffff;
                    text-decoration: none;
                    padding: 12px 24px;
                    border-radius: 6px;
                    font-weight: 500;
                  "
                  >View Application in Admin Portal</a
                >
              </div>

              <br />
              <p>Please take the necessary action at your earliest convenience.</p>
              <br />
              <p>
                Best Regards, <br />
                Team Taxmind
              </p>
            </div>
          </td>
        </tr>
        <tr>
          <td class="footer" style="background-color: #01afed; padding: 16px 48px">
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
              <tr>
                <td
                  align="center"
                  valign="middle"
                  class="contact-info"
                  style="
                    color: #ffffff;
                    font-size: 14px;
                    letter-spacing: 0.2px;
                    vertical-align: middle;
                  "
                >
                  <span>+353 871986494</span>
                  <span
                    class="contact-divider"
                    style="
                      display: inline-block;
                      width: 1px;
                      height: 19px;
                      background-color: #ffffff;
                      opacity: 0.5;
                      margin: 0 10px;
                      vertical-align: middle;
                    "
                  ></span>
                  <span>info@taxmind.ie</span>
                  <span
                    class="contact-divider"
                    style="
                      display: inline-block;
                      width: 1px;
                      height: 19px;
                      background-color: #ffffff;
                      opacity: 0.5;
                      margin: 0 10px;
                      vertical-align: middle;
                    "
                  ></span>
                  <!-- </td>
                            <td align="right" valign="middle" class="social-icons" style="text-align: right; vertical-align: middle;"> -->
                  <img
                    src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/X.png"
                    alt="Twitter"
                    class="social-icon"
                    style="
                      width: 16px;
                      height: 16px;
                      margin: 0 5px;
                      display: inline-block;
                      vertical-align: middle;
                    "
                  />
                  <img
                    src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/facebook.png"
                    alt="Facebook"
                    class="social-icon"
                    style="
                      width: 16px;
                      height: 16px;
                      margin: 0 5px;
                      display: inline-block;
                      vertical-align: middle;
                    "
                  />
                  <img
                    src="https://taxmind-dev-public.s3.eu-west-1.amazonaws.com/instagram.png"
                    alt="Instagram"
                    class="social-icon"
                    style="
                      width: 16px;
                      height: 16px;
                      margin: 0 5px;
                      display: inline-block;
                      vertical-align: middle;
                    "
                  />
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </div>
  </body>
</html>
