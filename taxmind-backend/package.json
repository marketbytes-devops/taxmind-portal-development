    "migrate:mongo-faqs:production": "tsx --env-file=.env.production src/db_migration_mongo_to_psql/migration/faq-migrations.ts",
    "migrate:mongo-queries:production": "tsx --env-file=.env.production src/db_migration_mongo_to_psql/migration/query-migrations.ts",
    "migrate:mongo-questionnaires:production": "tsx --env-file=.env.production src/db_migration_mongo_to_psql/migration/questionnaire-migrations.ts",
    "migrate:mongo-doc-categories:production": "tsx --env-file=.env.production src/db_migration_mongo_to_psql/migration/document-category-migrations.ts",
    "migrate:mongo-applications:production": "tsx --env-file=.env.production src/db_migration_mongo_to_psql/migration/application-migrations.ts",
    "db:update:user-phone-numbers:local": " npx tsx --env-file=.env.local src/scripts/userPhoneNumberUpdateJob.ts",
    "db:update:user-phone-numbers:production": " npx tsx --env-file=.env.production src/scripts/userPhoneNumberUpdateJob.ts",
    "delete-user:dev": "npx tsx --env-file=.env.development src/scripts/permanentUserDeletion.ts",
    "populate-trigram-hashes:local": "npx tsx --env-file=.env.local src/scripts/populateTrigramHashes.ts",
    "populate-trigram-hashes:dev": "npx tsx --env-file=.env.development src/scripts/populateTrigramHashes.ts",
    "populate-trigram-hashes:prod": "npx tsx --env-file=.env.production src/scripts/populateTrigramHashes.ts"
  },
