    "start:build:dev": "node --env-file=.env.development dist",
    "start:build:staging": "node --env-file=.env.staging dist",
    "start:build:prod": "node --env-file=.env.production dist",
    "build": "npx rimraf ./dist && npx tsc && cp -r ./src/mail/templates ./dist/mail/templates && cp -r ./src/database/migrations ./dist/database/migrations",
    "lint": "eslint --config eslint.config.js 'src/**/*.{js,ts,tsx}'",
    "lint:fix": "eslint --config eslint.config.js 'src/**/*.{js,ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{js,ts,json,md}'",
    "deploy:dev": "./deploy-dev.sh",
    "setup:revolut:webhook:local": "tsx --env-file=.env.local src/scripts/setupRevolutWebhook.ts",
    "setup:revolut:webhook:dev": "tsx --env-file=.env.development src/scripts/setupRevolutWebhook.ts",
