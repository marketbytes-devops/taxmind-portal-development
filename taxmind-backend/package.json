  "main": "index.js",
  "scripts": {
    "start": "node --env-file=.env dist/index.js",
    "start:local": "tsx watch --env-file=.env.local --clear-screen=false src/index.ts",
    "start:dev": "tsx watch --env-file=.env.development --clear-screen=false src/index.ts",
    "start:staging": "tsx watch --env-file=.env.staging src/index.ts",
    "start:prod": "tsx watch --env-file=.env.production src/index.ts",
    "db:generate": "tsx src/scripts/generate.ts",
    "db:generate:local": "drizzle-kit generate  --name applied-referral-code-points-claimed-field",
    "db:migrate:kit": "dotenvx run -f .env.local -- drizzle-kit migrate",
    "db:migrate:local": "tsx --env-file=.env.local src/scripts/migrate.ts",
    "db:migrate:dev": "tsx --env-file=.env.development src/scripts/migrate.ts",
    "db:migrate:staging": "tsx --env-file=.env.staging src/scripts/migrate.ts",
    "db:migrate:prod": "tsx --env-file=.env.production src/scripts/migrate.ts",
    "db:seed:local": "tsx --env-file=.env.local src/database/seeders/index.ts",
    "db:seed:dev": "tsx --env-file=.env.development src/database/seeders/index.ts",
    "db:seed:staging": "tsx --env-file=.env.staging src/database/seeders/index.ts",
    "db:seed:prod": "tsx --env-file=.env.production src/database/seeders/index.ts",
    "db:seed:super-admin:local": "tsx --env-file=.env.local src/scripts/seedSuperAdmin.ts",
    "db:seed:super-admin:dev": "tsx --env-file=.env.development src/scripts/seedSuperAdmin.ts",
    "db:seed:super-admin:staging": "tsx --env-file=.env.staging src/scripts/seedSuperAdmin.ts",
    "db:seed:super-admin:prod": "tsx --env-file=.env.production src/scripts/seedSuperAdmin.ts",
    "db:push:local": "dotenvx run -f .env.local -- drizzle-kit push",
    "db:studio:local": "dotenvx run -f .env.local -- drizzle-kit studio",
    "db:check:local": "dotenvx run -f .env.local -- drizzle-kit check",
