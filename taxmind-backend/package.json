    "migrate:mongo-users-chat:prod": "tsx --env-file=.env.production src/db_migration_mongo_to_psql/migration/chat-migrations.ts",
    "migrate:mongo-tax-credits:prod": "tsx --env-file=.env.production src/db_migration_mongo_to_psql/migration/tax-credits-migrations.ts",
